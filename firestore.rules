rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() {
      return request.auth != null;
    }

    function requesterDoc() {
      return get(/databases/$(database)/documents/controleAcesso/$(request.auth.token.email));
    }

    // Só o owner pode escrever. Admin foi removido — qualquer outro papel é leitura.
    function isOwner() {
      return signedIn()
        && exists(/databases/$(database)/documents/controleAcesso/$(request.auth.token.email))
        && requesterDoc().data.role == "owner";
    }

    function isAuthorized() {
      return signedIn()
        && exists(/databases/$(database)/documents/controleAcesso/$(request.auth.token.email));
    }

    match /controleAcessoMeta/{docId} {
      allow read: if signedIn();
      allow create: if signedIn()
        && docId == "config"
        && !exists(/databases/$(database)/documents/controleAcessoMeta/config)
        && request.resource.data.ownerEmail == request.auth.token.email;
      allow update, delete: if isOwner();
    }

    match /controleAcesso/{email} {
      allow read: if signedIn() && (request.auth.token.email == email || isOwner());
      allow list: if isOwner();
      allow create: if signedIn() && (
        (!exists(/databases/$(database)/documents/controleAcessoMeta/config)
          && request.auth.token.email == email
          && request.resource.data.role == "owner")
        || isOwner()
      );
      allow update, delete: if isOwner() || (signedIn() && request.auth.token.email == email && resource.data.role == "owner");
    }

    // Coleções do time: leitura por autorizados, escrita só do owner.
    match /rascunho/{docId} {
      allow read: if isAuthorized();
      allow write: if isOwner();
    }

    match /dias/{docId} {
      allow read: if isAuthorized();
      allow write: if isOwner();
    }

    // Configurações internas: leitura por autorizados (o dashboard lê),
    // escrita somente por admin/owner.
    match /metas/{docId} {
      allow read: if isAuthorized();
      allow write: if isOwner();
    }

    match /metasHistorico/{docId} {
      allow read: if isAuthorized();
      allow write: if isOwner();
    }

    match /custos/{docId} {
      allow read: if isAuthorized();
      allow write: if isOwner();
    }

    match /estoque/{docId} {
      allow read: if isAuthorized();
      allow write: if isOwner();
    }

    // Livro de movimentações do estoque (entradas/baixas/ajustes)
    match /estoque_movimentos/{docId} {
      allow read: if isAuthorized();
      allow write: if isOwner();
    }

    // Remessas do Full marcadas como resolvidas (sem gerar baixa)
    match /full_remessas/{docId} {
      allow read: if isAuthorized();
      allow write: if isOwner();
    }

    // Legacy: Allow authorized users read old data, writes only own uid
    match /usuarios/{uid}/{document=**} {
      allow read: if isAuthorized();
      allow write: if request.auth != null && request.auth.uid == uid;
    }
  }
}
